{
    "name": "chadmailer/chadmailer",
    "description": "Application de campagnes email avec rotation de lettres et personnalisation CSV",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "monolog/monolog": "^3.0",
        "symfony/console": "^6.4|^7.0",
        "symfony/mailer": "^6.4|^7.0",
        "symfony/brevo-mailer": "^6.4|^7.0",
        "symfony/http-client": "^6.4|^7.0",
        "league/csv": "^9.0",
        "guzzlehttp/guzzle": "^7.0",
        "symfony/amazon-mailer": "^6.4",
        "symfony/sendgrid-mailer": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "ChadMailer\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "build": "php -d phar.readonly=0 build.php"
    }
}
